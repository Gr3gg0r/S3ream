{
  "name": "s3ream",
  "version": "0.1.0",
  "description": "Local-first Electron app that converts videos to multi-bitrate HLS and uploads the stream to any S3-compatible storage — no transcoding server required.",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:slow": "dotenv -e .env.slow -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:testing": "dotenv -e .env.testing -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:staging": "dotenv -e .env.staging -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:production": "dotenv -e .env.production -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "S3REAM_TEST_INTEGRATION=1 vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "dist": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder",
    "dist:mac": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --mac",
    "dist:win": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --win",
    "dist:linux": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@fontsource/inter": "^5.2.8",
    "daisyui": "^4.10.2",
    "dotenv": "^16.4.5",
    "execa": "^9.1.0",
    "minio": "^8.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "dotenv-cli": "^7.3.0",
    "electron": "^43.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.4",
    "typescript-eslint": "^7.6.0",
    "vite": "^5.2.6",
    "vitest": "^2"
  },
  "engines": {
    "node": ">=18.16.0"
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "hls",
    "minio",
    "rustfs",
    "s3",
    "typescript",
    "video"
  ],
  "author": "Shahfiq Shah <shahfiq.dev@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@8.15.4"
}
