{
  "name": "s3ream",
  "version": "1.0.0",
  "description": "Local-first Electron app that converts videos to multi-bitrate HLS and uploads the stream to any S3-compatible storage — no transcoding server required.",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:slow": "dotenv -e .env.slow -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:testing": "dotenv -e .env.testing -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:staging": "dotenv -e .env.staging -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "dev:production": "dotenv -e .env.production -- ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "preview": "ELECTRON_RUN_AS_NODE= electron-vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "S3REAM_TEST_INTEGRATION=1 vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "dist": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder",
    "dist:mac": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --mac",
    "dist:win": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --win",
    "dist:linux": "pnpm run build && ELECTRON_RUN_AS_NODE= electron-builder --linux",
    "docs:css": "tailwindcss -i docs/src/landing.css -o docs/assets/landing.css --minify",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@fontsource/inter": "^5.2.8",
    "daisyui": "^5.6.18",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "minio": "^8.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "optionalDependencies": {
    "@ffmpeg-installer/darwin-arm64": "^4.1.5",
    "@ffmpeg-installer/darwin-x64": "^4.1.0",
    "@ffmpeg-installer/linux-arm": "^4.1.3",
    "@ffmpeg-installer/linux-arm64": "^4.1.4",
    "@ffmpeg-installer/linux-ia32": "^4.1.0",
    "@ffmpeg-installer/linux-x64": "^4.1.0",
    "@ffmpeg-installer/win32-ia32": "^4.1.0",
    "@ffmpeg-installer/win32-x64": "^4.1.0",
    "@ffprobe-installer/darwin-arm64": "^5.0.1",
    "@ffprobe-installer/darwin-x64": "^5.1.0",
    "@ffprobe-installer/linux-arm": "^5.2.0",
    "@ffprobe-installer/linux-arm64": "^5.2.0",
    "@ffprobe-installer/linux-ia32": "^5.2.0",
    "@ffprobe-installer/linux-x64": "^5.2.0",
    "@ffprobe-installer/win32-ia32": "^5.1.0",
    "@ffprobe-installer/win32-x64": "^5.1.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "electron-vite>vite": "8",
        "eslint-plugin-react>eslint": "10"
      }
    }
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "hls",
    "minio",
    "rustfs",
    "s3",
    "typescript",
    "video"
  ],
  "author": "Shahfiq Shah <shahfiq.dev@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@8.15.4"
}
