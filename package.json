{
  "name": "mkp-upload-services",
  "version": "0.1.0",
  "description": "Electron uploader that converts videos to HLS and pushes assets to S3-compatible storage.",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:slow": "dotenv -e .env.slow -- electron-vite dev",
    "dev:testing": "dotenv -e .env.testing -- electron-vite dev",
    "dev:staging": "dotenv -e .env.staging -- electron-vite dev",
    "dev:production": "dotenv -e .env.production -- electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "daisyui": "^4.10.2",
    "dotenv": "^16.4.5",
    "execa": "^9.1.0",
    "minio": "^8.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.2.0",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.4",
    "vite": "^5.2.6"
  },
  "engines": {
    "node": ">=18.16.0"
  },
  "keywords": [
    "electron",
    "ffmpeg",
    "minio",
    "s3",
    "hls",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@8.15.4"
}
